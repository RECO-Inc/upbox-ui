{
  "name": "@reco-inc/upbox-ui",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "version": "0.1.0",
  "type": "module",
  "description": "Upbox Design System - Vue 3 Component Library",
  "license": "UNLICENSED",
  "private": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./style.css": "./dist/upbox-ui.css",
    "./tailwind-preset": {
      "import": "./tailwind-preset.mjs",
      "require": "./tailwind-preset.cjs"
    }
  },
  "files": [
    "dist",
    "tailwind-preset.cjs",
    "tailwind-preset.mjs"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-i18n": "^11.0.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.10.0",
    "@vueuse/core": "^14.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.546.0",
    "reka-ui": "^2.6.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.3",
    "vue": "^3.5.22",
    "vue-i18n": "^11.2.8",
    "vue-tsc": "^3.1.0"
  }
}
